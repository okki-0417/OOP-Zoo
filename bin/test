#!/usr/bin/env bash
# テストランナー。通常は `bundle exec rspec`。
# この開発機ではシステム Ruby が古い(2.5)ため、micromamba の "zoo" 環境
# (Ruby 3.3)があればそれを使う。ユーザーの環境では単に bundle exec が走る。
set -euo pipefail

MM="$HOME/.micromamba/bin/micromamba"
if [ -x "$MM" ] && "$MM" env list 2>/dev/null | grep -q '\bzoo\b'; then
  export MAMBA_ROOT_PREFIX="$HOME/.micromamba"
  exec "$MM" run -n zoo bundle exec rspec "$@"
fi

exec bundle exec rspec "$@"

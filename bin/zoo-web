#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift File.expand_path('../lib', __dir__)
require 'zoo'
require 'fileutils'

# 長時間動くサーバなので SQLite に永続化する(プロセスをまたいで状態が残る)。
# 保存先は ZOO_DB で差し替え可能。
db_path = ENV.fetch('ZOO_DB', File.expand_path('../tmp/zoo-web.db', __dir__))
FileUtils.mkdir_p(File.dirname(db_path))

Zoo::Presentation::Web.set(:container, Zoo::Composition::Container.new(database: db_path))
Zoo::Presentation::Web.run!(host: '127.0.0.1', port: 4567)

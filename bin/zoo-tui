#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift File.expand_path('../lib', __dir__)
require 'zoo'

# セーブファイルがあれば復元、無ければ新規。セーブはメニューの「セーブする」で。
save_path = Zoo::Presentation::Tui::SAVE_PATH
container =
  if Zoo::Infrastructure::Persistence::Snapshot.exist?(save_path)
    puts "セーブデータを読み込みました（#{save_path}）"
    Zoo::Composition::Container.load(save_path)
  else
    Zoo::Composition::Container.new
  end

Zoo::Presentation::Tui.new(container: container).run
